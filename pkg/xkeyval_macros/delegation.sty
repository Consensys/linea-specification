\makeatletter

\define@cmdkey [AUTH] {var} {anchorRow}           {}
\define@cmdkey [AUTH] {var} {relOffset}           {}
\define@cmdkey [AUTH] {var} {condition}           {}
\define@cmdkey [AUTH] {var} {delegationAddressHi} {}
\define@cmdkey [AUTH] {var} {delegationAddressLo} {}
\define@cmdkey [AUTH] {var} {checkPostDelegation} {}


\presetkeys    [AUTH] {var} {
	anchorRow           = \missingParameter,
	relOffset           = \missingParameter,
	condition           = \missingParameter,
	delegationAddressHi = \missingParameter,
	delegationAddressLo = \missingParameter,
	checkPostDelegation = \missingParameter,
}{}



% AUTH
\newcommand{\accSameDelegationAddress}[1]{
	\setkeys[AUTH]{var}{#1}
	\accountSignifier\sameSignifier\texttt{DelegationAddress}
	_{\cmdAUTH@var@anchorRow}
	\big[ \cmdAUTH@var@relOffset \big]
}
\newcommand{\accSetDelegationAddress}[1]{
	\setkeys[AUTH]{var}{#1}
	\texttt{setDelegationAddress} _{\cmdAUTH@var@anchorRow}
	\left[ \begin{array}{ll}
		\utt{Rel.  row    offset:}   & \cmdAUTH@var@relOffset           \\
		\utt{Delegation address hi:} & \cmdAUTH@var@delegationAddressHi \\
		\utt{Delegation address lo:} & \cmdAUTH@var@delegationAddressLo \\
	\end{array} \right]
}

